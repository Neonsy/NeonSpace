{
    "name": "neonspace",
    "private": true,
    "packageManager": "pnpm@11.1.2",
    "type": "module",
    "imports": {
        "@/*": "./src/*"
    },
    "scripts": {
        "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./tooling/instrument.server.mjs' vite dev --port 3000\"",
        "build": "vite build && node -e \"require('node:fs').copyFileSync('tooling/instrument.server.mjs', '.output/server/instrument.server.mjs')\"",
        "preview": "vite preview",
        "test": "vitest run --config tooling/vitest.config.ts",
        "lint": "eslint -c tooling/eslint.config.js",
        "format": "prettier --config tooling/prettier.config.js --write . && eslint -c tooling/eslint.config.js --fix",
        "check": "prettier --config tooling/prettier.config.js --check .",
        "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
    },
    "dependencies": {
        "@sentry/tanstackstart-react": "^10.53.1",
        "@t3-oss/env-core": "^0.13.11",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-form": "latest",
        "@tanstack/react-query": "latest",
        "@tanstack/react-query-devtools": "latest",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/router-plugin": "^1.167.35",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv-cli": "^11.0.0",
        "lucide-react": "^1.14.0",
        "nitro": "npm:nitro-nightly@3.0.1-20260512-093145-0498ce70",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/typography": "^0.5.19",
        "@tanstack/devtools-vite": "latest",
        "@tanstack/eslint-config": "latest",
        "@tanstack/eslint-plugin-query": "^5.100.10",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vitest": "^4.1.6"
    }
}
